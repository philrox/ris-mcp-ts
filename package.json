{
  "name": "ris-mcp-ts",
  "version": "1.1.1",
  "mcpName": "io.github.philrox/ris",
  "description": "MCP Server for Austrian Legal Information System (RIS) - TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ris-mcp-ts": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev:http": "tsx src/http.ts",
    "inspect": "pnpm dlx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prebuild": "pnpm run typecheck",
    "prepublishOnly": "pnpm run check && pnpm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cheerio": "^1.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-import-x>eslint": "$eslint"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "allowedDeprecatedVersions": {
      "git-raw-commits": "4.0.0",
      "whatwg-encoding": "3.1.1"
    }
  },
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ris",
    "rechtsinformationssystem",
    "austria",
    "legal",
    "law"
  ],
  "author": "philrox <phil@resultsbymagic.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philrox/ris-mcp-ts.git"
  },
  "homepage": "https://github.com/philrox/ris-mcp-ts#readme",
  "bugs": {
    "url": "https://github.com/philrox/ris-mcp-ts/issues"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE"
  ]
}
